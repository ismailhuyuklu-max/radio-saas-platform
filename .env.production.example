# =============================================================================
# AdCast Pro — Üretim Ortamı Yapılandırma Şablonu (.env.production.example)
# =============================================================================
# Bu dosyayı `.env.production` olarak kopyalayıp tüm değerleri doldurun.
# `bin/setup-prod.sh` script'i bunu otomatik olarak güvenli secret'larla
# üretebilir: `bash bin/setup-prod.sh` (komut sonrası `.env.production`
# dosyası oluşur, mevcut secret'ları override etmez).
#
# REPO'ya KOMMİT EDİLMEZ — .gitignore'da zaten dışlandı.
# =============================================================================

# ----- Ortam -----
# `production` zorunlu. Hatalı kurulum (`local`/`development`) display_errors
# açar, NOC tipi HTML 500 sızıntısı geri gelir.
APP_ENV=production
APP_DEBUG=0

# 32 byte güvenli random key. JWT imzası ve MFA challenge HMAC için.
# Boş bırakırsanız JwtService production'da fail-closed atar.
#   openssl rand -base64 32
APP_KEY=REPLACE_WITH_OPENSSL_RAND_BASE64_32

# Public origin (Caddy/nginx önünde TLS varsa https://, yoksa http://).
# Frontend cookie SameSite + signed-URL üreteçleri bu URL'i kullanır.
APP_URL=https://adcastpro.com

# ----- PostgreSQL -----
# Default 'radio_saas_password' SADECE LOCAL'da kabul edilir. Prod'da
# 32+ char güçlü parola zorunlu.
POSTGRES_DB=radio_saas
POSTGRES_USER=radio_saas
POSTGRES_PASSWORD=REPLACE_WITH_OPENSSL_RAND_HEX_24

# ----- MinIO (S3-uyumlu obje deposu) -----
# Default 'minioadmin/minioadmin123' SADECE LOCAL içindir.
MINIO_ROOT_USER=REPLACE_WITH_OPENSSL_RAND_HEX_16
MINIO_ROOT_PASSWORD=REPLACE_WITH_OPENSSL_RAND_HEX_24

# CORS allow-origin (boş bırakılırsa nginx config'teki PLACEHOLDER kullanılır).
# AdCast Pro'yu alt domain ağacından çağıracaksanız: https://*.adcastpro.com
MINIO_API_CORS_ALLOW_ORIGIN=https://adcastpro.com

# ----- Backup -----
# Yedek aralığı (saat). Default 24 = günlük.
BACKUP_INTERVAL_HOURS=24

# ----- Audit retention (Faz H5-3) -----
# audit_logs tablosunda kaç gün sakla? Master prompt: yasal kayıt 180 gün.
# 0 yapmayın — audit log iz takibi için.
AUDIT_RETENTION_DAYS=180

# ----- Trusted reverse proxy (Faz H3-4) -----
# nginx/Caddy/Cloudflare arkasındaysanız buraya o IP'leri yazın (virgülle).
# `X-Forwarded-For` ilk hop SADECE bu IP'lerden gelirse kabul edilir.
# Boş bırakılırsa hiçbir XFF güvenilmez (en güvenli).
# Caddy sidecar kullanıyorsanız (--profile tls) Caddy container'ının
# radio_network içindeki IP'sini eklemeniz gerekir; örnek: 172.20.0.X
TRUSTED_PROXY_IPS=

# ----- TLS terminator (Faz H3-5) -----
# Caddy sidecar opsiyoneldir. Aktif etmek için:
#   docker compose --env-file .env.production \
#     -f docker-compose.prod.yml --profile tls up -d
# ACME (Let's Encrypt) iletişim e-postası — expiry uyarıları için zorunlu.
ACME_EMAIL=ops@adcastpro.com

# ----- Slow query log (Faz H5-2) -----
# Eşik ms değerinden uzun süren PG sorgularını Logger::warning ile yapısal
# log'a yazar. 0 ya da boş = log kapalı (PDO stock). Üretimde 200 öneri.
DB_SLOW_QUERY_MS=200

# ----- Bcrypt cost (Faz H3-5) -----
# Şifre hash maliyeti. 10 = ~250ms/hash, 12 = ~1s/hash, 14 = ~4s/hash.
# Yüksek cost brute-force defansı +; login UX'ini yavaşlatır.
# Aralık [10..15] dışı değerler otomatik clamp edilir.
BCRYPT_COST=12

# ----- Loglama -----
TZ=Europe/Istanbul
