{
  "SyncClient": {
    "ApiBaseUrl": "https://api.adcastpro.com",
    "FilesBaseUrl": "https://files.adcastpro.com",
    "SignalRHubUrl": "https://sync.adcastpro.com/hubs/manifest",
    "ClientVersion": "1.0.0",
    "PollIntervalSeconds": 60,
    "HeartbeatIntervalSeconds": 60,
    "NewsReadyMinutesBefore": 15,
    "AutoStartWithWindows": true,
    "AutoUpdateCheckIntervalHours": 6,
    "ParallelDownloadWorkers": 3,
    "SignalREnabled": true,
    "Folders": {
      "News": "D:\\AdCastPro\\News",
      "Ads": "D:\\AdCastPro\\Ads",
      "MediaPlans": "D:\\AdCastPro\\MediaPlan",
      "Sponsors": "D:\\AdCastPro\\Sponsors",
      "Emergency": "D:\\AdCastPro\\Emergency",
      "Promo": "D:\\AdCastPro\\Promo",
      "Jingle": "D:\\AdCastPro\\Jingle",
      "Regional": "D:\\AdCastPro\\Regional",
      "National": "D:\\AdCastPro\\National",
      "Archive": "D:\\AdCastPro\\Archive",
      "Temp": "D:\\AdCastPro\\Temp",
      "Logs": "D:\\AdCastPro\\Logs"
    },
    "Retry": {
      "MaxAttempts": 5,
      "InitialDelayMs": 1000,
      "BackoffMultiplier": 2.0,
      "MaxDelayMs": 300000
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.AspNetCore.SignalR": "Information"
    }
  }
}
