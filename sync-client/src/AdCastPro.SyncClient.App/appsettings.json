{
  "SyncClient": {
    "ApiBaseUrl": "https://adcastpro.com",
    "ClientVersion": "1.0.0",
    "PollIntervalSeconds": 60,
    "HeartbeatIntervalSeconds": 60,
    "NewsReadyMinutesBefore": 15,
    "AutoStartWithWindows": true,
    "Folders": {
      "News": "C:\\AdCastPro\\Haberler",
      "Ads": "C:\\AdCastPro\\Reklamlar",
      "MediaPlans": "C:\\AdCastPro\\MedyaPlanlari",
      "Sponsors": "C:\\AdCastPro\\Sponsorlar",
      "Archive": "C:\\AdCastPro\\Archive",
      "Temp": "C:\\AdCastPro\\Temp",
      "Logs": "C:\\AdCastPro\\Logs"
    },
    "Retry": {
      "MaxAttempts": 5,
      "InitialDelayMs": 1000,
      "BackoffMultiplier": 2.0,
      "MaxDelayMs": 300000
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}
