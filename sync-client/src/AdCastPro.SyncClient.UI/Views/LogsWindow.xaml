<Window
    x:Class="AdCastPro.SyncClient.UI.Views.LogsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Loglar — AdCast Pro Sync"
    Width="900"
    Height="600"
    Background="{StaticResource BgDark}"
    WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Filtre:" Foreground="{StaticResource FgMuted}"
                       VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox Grid.Column="1" Height="28" Padding="8,0"
                     Background="{StaticResource BgCard}" Foreground="{StaticResource FgPrimary}"
                     BorderBrush="{StaticResource BorderColor}" VerticalContentAlignment="Center"
                     Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Column="2" Content="Yenile" Padding="12,4" Margin="8,0,0,0"
                    Background="{StaticResource BgCard}" Foreground="{StaticResource FgPrimary}"
                    BorderBrush="{StaticResource BorderColor}" Command="{Binding RefreshCommand}" />
        </Grid>

        <Border Grid.Row="1" Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="6">
            <ListBox ItemsSource="{Binding Lines}" Background="Transparent" Foreground="{StaticResource FgPrimary}"
                     BorderThickness="0" FontFamily="Consolas" FontSize="12" />
        </Border>
    </Grid>
</Window>
