<Window
    x:Class="AdCastPro.SyncClient.UI.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="AdCast Pro Sync Client"
    Width="900"
    Height="600"
    Background="{StaticResource BgDark}"
    WindowStartupLocation="CenterScreen"
    MinWidth="700"
    MinHeight="500"
    Closing="OnClosing">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="AdCast Pro Sync" FontSize="24" FontWeight="Bold" Foreground="{StaticResource FgPrimary}" />
                <TextBlock Margin="0,4,0,0">
                    <Run Text="Radyo: " Foreground="{StaticResource FgMuted}" />
                    <Run Text="{Binding RadioName}" Foreground="{StaticResource FgPrimary}" FontWeight="SemiBold" />
                    <Run Text="  ·  Kullanıcı: " Foreground="{StaticResource FgMuted}" />
                    <Run Text="{Binding UserName}" Foreground="{StaticResource FgPrimary}" />
                </TextBlock>
            </StackPanel>
            <Button
                Grid.Column="1"
                Content="Yenile"
                Padding="14,8"
                Background="{StaticResource BgCard}"
                Foreground="{StaticResource FgPrimary}"
                BorderBrush="{StaticResource BorderColor}"
                Command="{Binding RefreshCommand}" />
        </Grid>

        <!-- Status panel -->
        <Border
            Grid.Row="1"
            Margin="0,20,0,16"
            Padding="20"
            CornerRadius="10"
            Background="{StaticResource BgCard}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="1">
            <StackPanel>
                <TextBlock Text="YAYINCILIK DURUMU" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource FgMuted}" Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="14" Height="14" Fill="{Binding StatusColor}" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource FgPrimary}"
                               FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Margin="0,12,0,0">
                    <Run Text="Son sync: " Foreground="{StaticResource FgMuted}" />
                    <Run Text="{Binding LastSyncTime}" Foreground="{StaticResource FgPrimary}" />
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Recent downloads -->
        <Border
            Grid.Row="2"
            CornerRadius="10"
            Background="{StaticResource BgCard}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="1">
            <DockPanel Margin="20">
                <TextBlock
                    DockPanel.Dock="Top"
                    Text="SON İNDİRİLEN DOSYALAR"
                    FontSize="11"
                    FontWeight="Bold"
                    Foreground="{StaticResource FgMuted}"
                    Margin="0,0,0,12" />
                <ListView
                    Background="Transparent"
                    Foreground="{StaticResource FgPrimary}"
                    BorderThickness="0"
                    ItemsSource="{Binding RecentDownloads}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Dosya" Width="280" DisplayMemberBinding="{Binding Filename}" />
                            <GridViewColumn Header="Boyut (KB)" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SizeBytes, StringFormat='{}{0:N0}'}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Tarih" Width="160" DisplayMemberBinding="{Binding DownloadedAt, StringFormat='dd MMM HH:mm:ss'}" />
                            <GridViewColumn Header="SHA-256" Width="200">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Checksum}" FontFamily="Consolas" FontSize="11" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Border>

        <!-- Footer actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,16,0,0">
            <Button Content="Ayarlar" Padding="14,8" Margin="0,0,8,0" Click="OnSettings"
                    Background="{StaticResource BgCard}" Foreground="{StaticResource FgPrimary}" BorderBrush="{StaticResource BorderColor}" />
            <Button Content="Loglar" Padding="14,8" Margin="0,0,8,0" Click="OnLogs"
                    Background="{StaticResource BgCard}" Foreground="{StaticResource FgPrimary}" BorderBrush="{StaticResource BorderColor}" />
        </StackPanel>
    </Grid>
</Window>
