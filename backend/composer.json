{
  "name": "haber/radio-saas-platform",
  "description": "Regional radio SaaS backend with MinIO, PostgreSQL and FFmpeg orchestration.",
  "license": "proprietary",
  "type": "project",
  "require": {
    "php": "^8.2",
    "aws/aws-sdk-php": "^3.0",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-pdo_pgsql": "*"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.11"
  },
  "autoload": {
    "psr-4": {
      "RadioSaaS\\": "src/"
    }
  },
  "scripts": {
    "worker": [
      "php bin/queue-worker.php"
    ],
    "stan": [
      "vendor/bin/phpstan analyse --memory-limit=512M"
    ],
    "test": [
      "php tests/RbacTest.php",
      "php tests/RevenueTest.php",
      "php tests/TotpTest.php",
      "php tests/MetricsTest.php",
      "php tests/ReportTest.php",
      "php tests/LoginThrottleTest.php",
      "php tests/HttpExceptionTest.php",
      "php tests/PaginationTest.php",
      "php tests/BroadcastSlotTest.php",
      "php tests/TrafficPlannerTest.php",
      "php tests/SmartPlacementTest.php",
      "php tests/PasswordPolicyTest.php",
      "php tests/RequestContextTest.php",
      "php tests/PasswordHasherTest.php",
      "php tests/LoggerTest.php"
    ],
    "test:e2e": [
      "php tests/rbac_e2e.php",
      "php tests/ad_e2e.php",
      "php tests/mfa_e2e.php",
      "php tests/security_e2e.php",
      "php tests/csrf_e2e.php",
      "php tests/traffic_e2e.php",
      "php tests/partner_e2e.php"
    ]
  }
}
