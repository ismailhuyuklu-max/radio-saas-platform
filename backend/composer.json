{
  "name": "haber/radio-saas-platform",
  "description": "Regional radio SaaS backend with MinIO, PostgreSQL and FFmpeg orchestration.",
  "license": "proprietary",
  "type": "project",
  "require": {
    "php": "^8.2",
    "aws/aws-sdk-php": "^3.0",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-pdo_pgsql": "*"
  },
  "autoload": {
    "psr-4": {
      "RadioSaaS\\": "src/"
    }
  },
  "scripts": {
    "worker": [
      "php bin/queue-worker.php"
    ],
    "test": [
      "php tests/RbacTest.php",
      "php tests/RevenueTest.php",
      "php tests/TotpTest.php",
      "php tests/MetricsTest.php"
    ],
    "test:e2e": [
      "php tests/rbac_e2e.php",
      "php tests/ad_e2e.php",
      "php tests/mfa_e2e.php"
    ]
  }
}
